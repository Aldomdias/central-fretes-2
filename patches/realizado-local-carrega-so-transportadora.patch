+const CACHE_TABELAS_COMPLETA_KEY = 'amd-fretes-cache-tabelas-completa-v1';
+const CACHE_TABELAS_TRANSPORTADORA_PREFIX = 'amd-fretes-cache-tabela-transportadora-v1:';
+const CACHE_TABELAS_TTL_MS = 1000 * 60 * 60 * 12;
+
+function normalizarNomeCache(value) {
+  return String(value || '')
+    .normalize('NFD')
+    .replace(/[\u0300-\u036f]/g, '')
+    .trim()
+    .toUpperCase()
+    .replace(/\s+/g, ' ');
+}
+
+function chaveCacheTransportadora(nome) {
+  return `${CACHE_TABELAS_TRANSPORTADORA_PREFIX}${normalizarNomeCache(nome)}`;
+}
+
+function lerCacheTabelas(key) {
+  try {
+    const raw = localStorage.getItem(key);
+    if (!raw) return null;
+    const parsed = JSON.parse(raw);
+    if (!parsed?.createdAt || !Array.isArray(parsed?.transportadoras)) return null;
+    if (Date.now() - Number(parsed.createdAt) > CACHE_TABELAS_TTL_MS) return null;
+    return parsed;
+  } catch {
+    return null;
+  }
+}
+
+function salvarCacheTabelas(key, transportadoras, meta = {}) {
+  try {
+    localStorage.setItem(key, JSON.stringify({
+      createdAt: Date.now(),
+      updatedAt: new Date().toISOString(),
+      transportadoras,
+      meta,
+    }));
+  } catch {
+    // Se o navegador bloquear ou o cache exceder limite, a simulação continua buscando do Supabase.
+  }
+}
+
+function filtrarTransportadoraExata(base = [], nome = '') {
+  const alvo = normalizarNomeCache(nome);
+  if (!alvo) return [];
+  return (base || []).filter((item) => normalizarNomeCache(item?.nome) === alvo);
+}
