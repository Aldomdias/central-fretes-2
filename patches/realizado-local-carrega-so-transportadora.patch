+
+      const emMemoria = filtrarTransportadoraExata(transportadorasTabela, nomeSelecionado);
+      if (emMemoria.length) {
+        setCacheTabelaInfo({ origem: 'memória', tipo: 'transportadora', nome: nomeSelecionado, total: emMemoria.length });
+        return emMemoria;
+      }
+
+      const cache = lerCacheTabelas(cacheKey);
+      if (cache?.transportadoras?.length) {
+        setTransportadorasTabela((prev) => {
+          const existentes = Array.isArray(prev) ? prev : [];
+          const nomes = new Set(existentes.map((item) => normalizarNomeCache(item?.nome)));
+          return [
+            ...existentes,
+            ...cache.transportadoras.filter((item) => !nomes.has(normalizarNomeCache(item?.nome))),
