+
+    // Modo completo: usa cache da base completa; se não houver, carrega tudo uma vez.
+    if (transportadorasTabela?.length && modoSimulacao === 'completo') return transportadorasTabela;
+
+    const cacheCompleto = lerCacheTabelas(CACHE_TABELAS_COMPLETA_KEY);
+    if (cacheCompleto?.transportadoras?.length) {
+      setTransportadorasTabela(cacheCompleto.transportadoras);
+      setCacheTabelaInfo({ origem: 'cache local', tipo: 'base completa', total: cacheCompleto.transportadoras.length, updatedAt: cacheCompleto.updatedAt });
+      return cacheCompleto.transportadoras;
+    }
+
+    setProgress((prev) => ({
+      ...(prev || {}),
+      etapa: 'Carregando tabelas completas',
+      percentual: 15,
+      mensagem: 'Modo completo: carregando todas as tabelas do Supabase. Depois ficará em cache local.',
+    }));
+    await nextFrame();
+    const base = await carregarBaseCompletaDb().catch(() => []);
+    const finalBase = base?.length ? base : transportadoras;
+    if (finalBase?.length) salvarCacheTabelas(CACHE_TABELAS_COMPLETA_KEY, finalBase, { tipo: 'base completa' });
+    setTransportadorasTabela(finalBase);
+    setCacheTabelaInfo({ origem: base?.length ? 'Supabase completo' : 'memória/store', tipo: 'base completa', total: finalBase.length });
